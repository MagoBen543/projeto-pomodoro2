generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Settings {
  id              Int      @id
  workTime        Int
  shortBreakTime  Int
  longBreakTime   Int
  updatedAt       DateTime @updatedAt
}

model Task {
  id             String   @id
  name           String
  duration       Int
  type           String
  startDate      String
  completeDate   String?
  interruptedAt  String?
  createdAt      DateTime @default(now())
}